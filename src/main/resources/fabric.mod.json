{
        "schemaVersion": 1,
        "id": "combatkeep",
        "version": "${version}",
        "name": "CombatKeep",
        "description": "A server-side Fabric mod that enables KeepInventory with combat penalties. Configurable item drop, respawn immunity, combat stats, and Solidus economy integration with 10% balance penalty on kill.",
        "authors": [
                "MOHD_Gs"
        ],
        "contact": {
                "homepage": "https://modrinth.com/user/MOHD_Gs",
                "sources": "https://github.com/mohd-gs/CombatKeep"
        },
        "license": "MIT",
        "icon": "assets/combatkeep/icon.png",
        "environment": "server",
        "entrypoints": {
                "main": [
                        "com.combatkeep.mod.CombatKeepMod"
                ]
        },
        "depends": {
                "fabricloader": ">=0.19.2",
                "minecraft": ">=26.1.1",
                "java": ">=25",
                "fabric-api": "*"
        },
        "suggests": {
                "solidus": "*"
        }
}
